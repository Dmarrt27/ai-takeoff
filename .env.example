ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model. Defaults to claude-fable-5.
# CLAUDE_MODEL=claude-sonnet-4-6
# Optional: reasoning effort for adaptive-thinking models (low|medium|high|max).
# Defaults to high. Higher = more accurate cross-referencing, more output tokens.
# CLAUDE_EFFORT=high
# Optional: sampling temperature — only honored on models that still accept it
# (ignored on Fable 5 / Opus 4.7+, where sampling params were removed).
# CLAUDE_TEMPERATURE=0
